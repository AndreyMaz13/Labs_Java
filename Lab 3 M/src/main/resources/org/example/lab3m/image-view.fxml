<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.lab3m.ImageViewerController">

    <top>
        <HBox spacing="10" alignment="CENTER">

            <Button fx:id="firstButton"
                    text="«"/>

            <Button fx:id="prevButton"
                    text="&lt;"/>

            <Button fx:id="nextButton"
                    text="&gt;"/>

            <Button fx:id="lastButton"
                    text="»"/>

            <Button fx:id="slideShowButton"
                    text="Автопросмотр"/>

            <ComboBox fx:id="filterBox"
                      prefWidth="120"/>

        </HBox>
    </top>

    <center>

        <ImageView fx:id="imageView"
                   preserveRatio="true"
                   fitWidth="800"
                   fitHeight="500"/>

    </center>

    <bottom>

        <VBox spacing="5">

            <Label fx:id="positionLabel"
                   text="0 из 0"/>

            <Label fx:id="fileInfoLabel"
                   text="Информация о файле"/>

            <Label fx:id="exifLabel"
                   text="EXIF"/>

        </VBox>

    </bottom>

</BorderPane>